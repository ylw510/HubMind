/* Chatbot UI Style - Inspired by chatbot-ui */

/* Layout */
.chatbot-layout {
  display: flex;
  height: 100vh;
  overflow: hidden;
  background: #0f0f0f;
  color: #ececec;
}

/* Sidebar */
.chatbot-sidebar {
  width: 260px;
  background: #171717;
  border-right: 1px solid #2d2d2d;
  display: flex;
  flex-direction: column;
  transition: width 0.2s ease;
  overflow: hidden;
}

.chatbot-sidebar.collapsed {
  width: 60px;
}

.chatbot-sidebar-header {
  padding: 12px;
  border-bottom: 1px solid #2d2d2d;
  display: flex;
  flex-direction: column;
  gap: 8px;
  position: relative;
}

.chatbot-sidebar-new-chat {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  background: #2d2d2d;
  color: #ececec;
  border: 1px solid #3d3d3d;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  width: 100%;
}

.chatbot-sidebar-new-chat:hover {
  background: #3d3d3d;
  border-color: #4d4d4d;
}

.chatbot-sidebar-search {
  position: relative;
}

.chatbot-sidebar-search-input {
  width: 100%;
  padding: 8px 12px;
  background: #1f1f1f;
  border: 1px solid #2d2d2d;
  border-radius: 6px;
  color: #ececec;
  font-size: 13px;
  transition: border-color 0.2s ease;
}

.chatbot-sidebar-search-input:focus {
  outline: none;
  border-color: #4d4d4d;
}

.chatbot-sidebar-search-input::placeholder {
  color: #6d6d6d;
}

.chatbot-sidebar-toggle {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  color: #9d9d9d;
  cursor: pointer;
  border-radius: 6px;
  transition: background 0.2s ease, color 0.2s ease;
}

.chatbot-sidebar-toggle:hover {
  background: #2d2d2d;
  color: #ececec;
}

.chatbot-sidebar-content {
  flex: 1;
  overflow-y: auto;
  padding: 8px;
}

.chatbot-sidebar-section {
  margin-bottom: 16px;
}

.chatbot-sidebar-section-title {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  color: #6d6d6d;
  padding: 8px 12px;
  letter-spacing: 0.5px;
}

.chatbot-sidebar-item-wrapper {
  display: flex;
  align-items: center;
  gap: 4px;
  position: relative;
  margin-bottom: 2px;
}

.chatbot-sidebar-item-wrapper:hover .chatbot-sidebar-item-delete {
  opacity: 1;
}

.chatbot-sidebar-item {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  padding: 10px 12px;
  background: transparent;
  border: none;
  border-radius: 8px;
  color: #9d9d9d;
  font-size: 14px;
  text-align: left;
  cursor: pointer;
  transition: all 0.2s ease;
}

.chatbot-sidebar-item:hover {
  background: #2d2d2d;
  color: #ececec;
}

.chatbot-sidebar-item.active {
  background: #2d5a3f;
  color: #4ade80;
}

.chatbot-sidebar-item-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chatbot-sidebar-item-delete {
  padding: 6px;
  background: transparent;
  border: none;
  border-radius: 6px;
  color: #6d6d6d;
  cursor: pointer;
  transition: all 0.2s ease;
  opacity: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chatbot-sidebar-item-delete:hover {
  background: #3d2d2d;
  color: #ff6b6b;
  opacity: 1;
}

.chatbot-sidebar-empty {
  padding: 24px;
  text-align: center;
  color: #6d6d6d;
  font-size: 13px;
}

.chatbot-sidebar-footer {
  padding: 12px;
  border-top: 1px solid #2d2d2d;
}

.chatbot-sidebar-brand {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #ececec;
  font-size: 14px;
  font-weight: 600;
}

/* Main Content */
.chatbot-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #0f0f0f;
}

.chatbot-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chatbot-messages {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.chatbot-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  text-align: center;
  padding: 48px 24px;
}

.chatbot-empty-icon {
  margin-bottom: 24px;
  color: #6d6d6d;
  opacity: 0.6;
}

.chatbot-empty-title {
  font-size: 28px;
  font-weight: 600;
  color: #ececec;
  margin-bottom: 12px;
}

.chatbot-empty-subtitle {
  font-size: 14px;
  color: #9d9d9d;
  max-width: 400px;
}

/* Message */
.chatbot-message {
  display: flex;
  gap: 16px;
  max-width: 800px;
  margin: 0 auto;
  width: 100%;
  position: relative;
}

.chatbot-message.user {
  flex-direction: row-reverse;
}

.chatbot-message-avatar {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2d2d2d;
  color: #9d9d9d;
}

.chatbot-message.user .chatbot-message-avatar {
  background: #4d4d4d;
  color: #ececec;
}

.chatbot-message-content-wrapper {
  flex: 1;
  position: relative;
  min-width: 0;
}

.chatbot-message-content {
  padding: 12px 16px;
  background: #1f1f1f;
  border: 1px solid #2d2d2d;
  border-radius: 12px;
  color: #ececec;
  font-size: 14px;
  line-height: 1.6;
  word-wrap: break-word;
}

.chatbot-message.user .chatbot-message-content {
  background: #2d2d2d;
  border-color: #3d3d3d;
}

/* Markdown 标题样式 */
.chatbot-message-content .chatbot-markdown-h1,
.chatbot-message-content h1 {
  font-size: 24px;
  font-weight: 700;
  margin: 24px 0 16px 0;
  padding-bottom: 8px;
  border-bottom: 2px solid #2d2d2d;
  color: #ececec;
}

.chatbot-message-content .chatbot-markdown-h1:first-child,
.chatbot-message-content h1:first-child {
  margin-top: 0;
}

.chatbot-message-content .chatbot-markdown-h2,
.chatbot-message-content h2 {
  font-size: 20px;
  font-weight: 600;
  margin: 20px 0 12px 0;
  padding-bottom: 6px;
  border-bottom: 1px solid #2d2d2d;
  color: #ececec;
}

.chatbot-message-content .chatbot-markdown-h3,
.chatbot-message-content h3 {
  font-size: 18px;
  font-weight: 600;
  margin: 16px 0 10px 0;
  color: #d4d4d4;
}

.chatbot-message-content .chatbot-markdown-h4,
.chatbot-message-content h4 {
  font-size: 16px;
  font-weight: 600;
  margin: 14px 0 8px 0;
  color: #c4c4c4;
}

/* Markdown 链接样式 */
.chatbot-message-content .chatbot-markdown-link,
.chatbot-message-content a {
  color: #4ade80;
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: all 0.2s ease;
}

.chatbot-message-content .chatbot-markdown-link:hover,
.chatbot-message-content a:hover {
  color: #86efac;
  border-bottom-color: #4ade80;
}

/* Markdown 段落 */
.chatbot-message-content p {
  margin: 12px 0;
  line-height: 1.7;
}

.chatbot-message-content p:last-child {
  margin-bottom: 0;
}

/* Markdown 列表 */
.chatbot-message-content ul,
.chatbot-message-content ol {
  margin: 12px 0;
  padding-left: 24px;
}

.chatbot-message-content li {
  margin: 6px 0;
  line-height: 1.6;
}

/* Markdown 代码块 */
.chatbot-message-content pre {
  background: #0f0f0f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  padding: 16px;
  overflow-x: auto;
  margin: 16px 0;
  font-size: 13px;
}

.chatbot-message-content code {
  font-family: 'Courier New', monospace;
  font-size: 13px;
}

.chatbot-message-content pre code {
  background: transparent;
  padding: 0;
}

.chatbot-message-content :not(pre) > code {
  background: #1f1f1f;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
  color: #86efac;
}

/* Markdown 引用 */
.chatbot-message-content blockquote {
  border-left: 4px solid #4ade80;
  padding-left: 16px;
  margin: 16px 0;
  color: #9d9d9d;
  font-style: italic;
}

/* Markdown 表格 */
.chatbot-message-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 16px 0;
}

.chatbot-message-content th,
.chatbot-message-content td {
  border: 1px solid #2d2d2d;
  padding: 8px 12px;
  text-align: left;
}

.chatbot-message-content th {
  background: #1f1f1f;
  font-weight: 600;
}

.chatbot-message-content tr:nth-child(even) {
  background: #171717;
}

/* Markdown 强调 */
.chatbot-message-content strong {
  font-weight: 600;
  color: #ececec;
}

.chatbot-message-content em {
  font-style: italic;
  color: #d4d4d4;
}

.chatbot-message-actions {
  display: flex;
  gap: 4px;
  margin-top: 8px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.chatbot-message:hover .chatbot-message-actions {
  opacity: 1;
}

.chatbot-message-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 6px;
  color: #9d9d9d;
  cursor: pointer;
  transition: all 0.2s ease;
}

.chatbot-message-action:hover {
  background: #2d2d2d;
  color: #ececec;
}

.chatbot-message-edit-input {
  width: 100%;
  min-height: 60px;
  padding: 12px 16px;
  background: #1f1f1f;
  border: 1px solid #4d4d4d;
  border-radius: 8px;
  color: #ececec;
  font-size: 14px;
  font-family: inherit;
  resize: vertical;
  transition: border-color 0.2s ease;
}

.chatbot-message-edit-input:focus {
  outline: none;
  border-color: #6d6d6d;
}

.chatbot-typing-indicator {
  display: flex;
  gap: 4px;
  padding: 8px 0;
}

.chatbot-typing-indicator span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #6d6d6d;
  animation: typing 1.4s infinite;
}

.chatbot-typing-indicator span:nth-child(2) {
  animation-delay: 0.2s;
}

.chatbot-typing-indicator span:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    opacity: 0.3;
    transform: translateY(0);
  }
  30% {
    opacity: 1;
    transform: translateY(-4px);
  }
}

/* Input Area */
.chatbot-input-area {
  padding: 24px;
  border-top: 1px solid #2d2d2d;
  background: #171717;
}

.chatbot-repo-selector {
  position: relative;
  margin-bottom: 12px;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
  width: 100%;
}

.chatbot-repo-selector-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  background: #1f1f1f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  color: #9d9d9d;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s ease;
  width: 100%;
  justify-content: space-between;
}

.chatbot-repo-selector-btn:hover {
  border-color: #3d3d3d;
  background: #2d2d2d;
}

.chatbot-repo-selector-btn.has-repo {
  background: #1f3a2f;
  border-color: #2d5a3f;
  color: #4ade80;
}

.chatbot-repo-selector-text {
  flex: 1;
  text-align: left;
}

.chatbot-repo-selector-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  color: #9d9d9d;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.chatbot-repo-selector-remove:hover {
  background: #2d2d2d;
  color: #ececec;
}

.chatbot-repo-dropdown {
  position: absolute;
  bottom: calc(100% + 8px);
  left: 0;
  right: 0;
  max-height: 400px;
  background: #1f1f1f;
  border: 1px solid #2d2d2d;
  border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chatbot-repo-search {
  position: relative;
  padding: 12px;
  border-bottom: 1px solid #2d2d2d;
}

.chatbot-repo-search-icon {
  position: absolute;
  left: 24px;
  top: 50%;
  transform: translateY(-50%);
  color: #6d6d6d;
  pointer-events: none;
}

.chatbot-repo-search-input {
  width: 100%;
  padding: 10px 14px 10px 40px;
  background: #0f0f0f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  color: #ececec;
  font-size: 14px;
  transition: border-color 0.2s ease;
}

.chatbot-repo-search-input:focus {
  outline: none;
  border-color: #4d4d4d;
}

.chatbot-repo-count {
  padding: 8px 12px;
  border-bottom: 1px solid #2d2d2d;
  color: #6d6d6d;
  font-size: 12px;
  text-align: center;
  background: #171717;
}

.chatbot-repo-list {
  flex: 1;
  overflow-y: auto;
  max-height: 320px;
  padding: 4px;
}

.chatbot-repo-loading,
.chatbot-repo-empty {
  padding: 24px;
  text-align: center;
  color: #6d6d6d;
  font-size: 14px;
}

.chatbot-repo-error {
  padding: 24px;
  text-align: center;
}

.chatbot-repo-error-title {
  font-size: 14px;
  font-weight: 600;
  color: #ef4444;
  margin-bottom: 8px;
}

.chatbot-repo-error-message {
  font-size: 13px;
  color: #9d9d9d;
  margin-bottom: 12px;
  line-height: 1.5;
}

.chatbot-repo-error-hint {
  font-size: 12px;
  color: #6d6d6d;
  margin-top: 8px;
}

.chatbot-repo-item {
  width: 100%;
  padding: 12px;
  background: transparent;
  border: none;
  border-radius: 8px;
  text-align: left;
  cursor: pointer;
  transition: all 0.2s ease;
  margin-bottom: 2px;
}

.chatbot-repo-item:hover {
  background: #2d2d2d;
}

.chatbot-repo-item.selected {
  background: #1f3a2f;
  border: 1px solid #2d5a3f;
}

.chatbot-repo-item-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.chatbot-repo-item-icon {
  flex-shrink: 0;
  color: #9d9d9d;
}

.chatbot-repo-item-name {
  flex: 1;
  font-size: 14px;
  font-weight: 500;
  color: #ececec;
}

.chatbot-repo-item-badge {
  font-size: 11px;
  padding: 2px 6px;
  background: #2d2d2d;
  border: 1px solid #3d3d3d;
  border-radius: 4px;
  color: #9d9d9d;
  text-transform: uppercase;
}

.chatbot-repo-item-desc {
  font-size: 13px;
  color: #9d9d9d;
  margin: 4px 0 6px 22px;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.chatbot-repo-item-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-left: 22px;
  font-size: 12px;
  color: #6d6d6d;
}

.chatbot-repo-item-lang {
  color: #9d9d9d;
}

.chatbot-repo-item-stars {
  color: #6d6d6d;
}

.chatbot-input-form {
  display: flex;
  gap: 12px;
  align-items: flex-end;
  max-width: 800px;
  margin: 0 auto;
  width: 100%;
}

.chatbot-input {
  flex: 1;
  padding: 14px 18px;
  background: #1f1f1f;
  border: 1px solid #2d2d2d;
  border-radius: 12px;
  color: #ececec;
  font-size: 14px;
  font-family: inherit;
  resize: none;
  min-height: 48px;
  max-height: 200px;
  transition: all 0.2s ease;
  line-height: 1.5;
}

.chatbot-input:focus {
  outline: none;
  border-color: #4d4d4d;
  box-shadow: 0 0 0 3px rgba(77, 77, 77, 0.1);
}

.chatbot-input::placeholder {
  color: #6d6d6d;
}

.chatbot-send-btn {
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2d2d2d;
  color: #ececec;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.chatbot-send-btn:hover:not(:disabled) {
  background: #3d3d3d;
  transform: translateY(-1px);
}

.chatbot-send-btn:disabled {
  background: #1f1f1f;
  color: #6d6d6d;
  cursor: not-allowed;
  opacity: 0.6;
}

.chatbot-footer {
  text-align: center;
  margin-top: 12px;
}

.chatbot-footer-text {
  font-size: 12px;
  color: #6d6d6d;
}

.rotated {
  transform: rotate(180deg);
}

/* Issue Panel */
.chatbot-layout.with-issue-panel {
  position: relative;
}

.chatbot-messages.with-panel {
  margin-right: 400px;
  transition: margin-right 0.3s ease;
}

.issue-panel {
  position: fixed;
  right: 0;
  top: 0;
  bottom: 0;
  width: 400px;
  background: #1f1f1f;
  border-left: 1px solid #2d2d2d;
  display: flex;
  flex-direction: column;
  z-index: 100;
  box-shadow: -4px 0 24px rgba(0, 0, 0, 0.3);
}

.issue-panel-header {
  padding: 16px;
  border-bottom: 1px solid #2d2d2d;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #171717;
}

.issue-panel-header-content {
  flex: 1;
}

.issue-panel-title {
  font-size: 16px;
  font-weight: 600;
  color: #ececec;
  margin: 0 0 4px 0;
}

.issue-panel-repo {
  font-size: 12px;
  color: #9d9d9d;
}

.issue-panel-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  border-radius: 6px;
  color: #9d9d9d;
  cursor: pointer;
  transition: all 0.2s ease;
}

.issue-panel-close:hover {
  background: #2d2d2d;
  color: #ececec;
}

.issue-panel-content {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
}

.issue-panel-loading {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px;
  color: #9d9d9d;
  font-size: 14px;
}

.issue-panel-loading .spin {
  animation: spin 1s linear infinite;
}

.issue-panel-similar {
  padding: 12px;
  background: #2d2d2d;
  border: 1px solid #3d3d3d;
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 13px;
  color: #ececec;
}

.issue-panel-similar {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.issue-panel-similar-list {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.issue-panel-similar-item {
  color: #4ade80;
  text-decoration: none;
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
  transition: background 0.2s ease;
}

.issue-panel-similar-item:hover {
  background: #2d2d2d;
  text-decoration: underline;
}

.issue-panel-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.issue-panel-field {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.issue-panel-label {
  font-size: 13px;
  font-weight: 500;
  color: #ececec;
}

.issue-panel-input {
  padding: 10px 14px;
  background: #0f0f0f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  color: #ececec;
  font-size: 14px;
  transition: border-color 0.2s ease;
}

.issue-panel-input:focus {
  outline: none;
  border-color: #4d4d4d;
}

.issue-panel-textarea {
  padding: 10px 14px;
  background: #0f0f0f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  color: #ececec;
  font-size: 14px;
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
  resize: vertical;
  min-height: 200px;
  transition: border-color 0.2s ease;
  line-height: 1.6;
}

.issue-panel-textarea:focus {
  outline: none;
  border-color: #4d4d4d;
}

.issue-panel-selector {
  position: relative;
}

.issue-panel-selector-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background: #0f0f0f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  color: #9d9d9d;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s ease;
  width: 100%;
  text-align: left;
}

.issue-panel-selector-btn:hover {
  border-color: #3d3d3d;
  background: #171717;
}

.issue-panel-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  right: 0;
  max-height: 300px;
  background: #1f1f1f;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  z-index: 1000;
  overflow-y: auto;
  padding: 4px;
}

.issue-panel-dropdown-loading,
.issue-panel-dropdown-empty {
  padding: 16px;
  text-align: center;
  color: #6d6d6d;
  font-size: 13px;
}

.issue-panel-dropdown-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  cursor: pointer;
  border-radius: 6px;
  transition: background 0.2s ease;
  font-size: 13px;
  color: #ececec;
}

.issue-panel-dropdown-item:hover {
  background: #2d2d2d;
}

.issue-panel-dropdown-item input[type="checkbox"] {
  cursor: pointer;
}

.issue-panel-label-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
  color: #fff;
}

.issue-panel-label-desc {
  font-size: 12px;
  color: #9d9d9d;
  margin-left: auto;
}

.issue-panel-avatar {
  width: 20px;
  height: 20px;
  border-radius: 50%;
}

.issue-panel-selected {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}

.issue-panel-selected-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  background: #2d2d2d;
  border: 1px solid #3d3d3d;
  border-radius: 16px;
  font-size: 12px;
  color: #ececec;
}

.issue-panel-selected-avatar {
  width: 16px;
  height: 16px;
  border-radius: 50%;
}

.issue-panel-selected-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 16px;
  height: 16px;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  color: #9d9d9d;
  cursor: pointer;
  transition: all 0.2s ease;
  margin-left: 4px;
}

.issue-panel-selected-remove:hover {
  background: #3d3d3d;
  color: #ececec;
}

.issue-panel-footer {
  padding: 16px;
  border-top: 1px solid #2d2d2d;
  display: flex;
  gap: 12px;
  justify-content: flex-end;
  background: #171717;
}

.issue-panel-cancel {
  padding: 10px 20px;
  background: transparent;
  border: 1px solid #2d2d2d;
  border-radius: 8px;
  color: #ececec;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.issue-panel-cancel:hover {
  background: #2d2d2d;
  border-color: #3d3d3d;
}

.issue-panel-submit {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: #2d5a3f;
  border: 1px solid #4ade80;
  border-radius: 8px;
  color: #4ade80;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.issue-panel-submit:hover:not(:disabled) {
  background: #1f3a2f;
  border-color: #4ade80;
  transform: translateY(-1px);
}

.issue-panel-submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* Scrollbar */
.chatbot-sidebar-content::-webkit-scrollbar,
.chatbot-messages::-webkit-scrollbar,
.chatbot-repo-list::-webkit-scrollbar {
  width: 8px;
}

.chatbot-sidebar-content::-webkit-scrollbar-track,
.chatbot-messages::-webkit-scrollbar-track,
.chatbot-repo-list::-webkit-scrollbar-track {
  background: transparent;
}

.chatbot-sidebar-content::-webkit-scrollbar-thumb,
.chatbot-messages::-webkit-scrollbar-thumb,
.chatbot-repo-list::-webkit-scrollbar-thumb {
  background: #2d2d2d;
  border-radius: 4px;
}

.chatbot-sidebar-content::-webkit-scrollbar-thumb:hover,
.chatbot-messages::-webkit-scrollbar-thumb:hover,
.chatbot-repo-list::-webkit-scrollbar-thumb:hover {
  background: #3d3d3d;
}
